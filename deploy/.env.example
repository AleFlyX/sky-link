DB_NAME=skylink
DB_USERNAME=skylink
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-root-password

JWT_SECRET=replace-with-a-random-secret-longer-than-32-bytes
SKYLINK_COLLABORATION_TICKET_SECRET=replace-with-another-random-secret-longer-than-32-bytes
SKYLINK_COLLABORATION_SERVICE_TOKEN=replace-with-a-service-token-longer-than-32-bytes

NGINX_PORT=80

# Replace localhost with your public domain in production.
SKYLINK_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost
COLLABORATION_ALLOWED_ORIGINS=http://localhost

# In production, prefer wss://your-domain/collaboration behind TLS.
SKYLINK_COLLABORATION_WEBSOCKET_URL=ws://localhost/collaboration

# Optional bootstrap administrator
# SKYLINK_BOOTSTRAP_ADMIN_ENABLED=false
# SKYLINK_BOOTSTRAP_ADMIN_USERNAME=
# SKYLINK_BOOTSTRAP_ADMIN_PASSWORD=
# SKYLINK_BOOTSTRAP_ADMIN_NICKNAME=
# SKYLINK_BOOTSTRAP_ADMIN_EMAIL=
# SKYLINK_BOOTSTRAP_ADMIN_PHONE=
