server:
  port: 8080

spring:
  application:
    name: land
  datasource:
    url: jdbc:mysql://localhost:3306/skylink?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
    username: root
    password: 123456
    driver-class-name: com.mysql.cj.jdbc.Driver
  sql:
    init:
      mode: always
      schema-locations: classpath:schema.sql
      data-locations: classpath:data.sql
      continue-on-error: false

mybatis-plus:
  mapper-locations: "classpath*:/mapper/**/*.xml"
  type-aliases-package: com.skylink.land.entity
  configuration:
    map-underscore-to-camel-case: true
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl
  global-config:
    db-config:
      id-type: assign_id
      logic-delete-field: deleted
      logic-delete-value: 1
      logic-not-delete-value: 0

logging:
  level:
    root: INFO
    com.skylink.land: DEBUG

skylink:
  jwt:
    issuer: sky-link
    secret: replace-with-a-random-secret-longer-than-32-bytes
    ttl: 24h
    refresh-ttl: 7d
    header: Authorization
    token-prefix: "Bearer "
    refresh-cookie:
      name: skylink_refresh_token
      path: /api/v1/auth
      domain:
      http-only: true
      secure: false
      same-site: Lax
    exclude-paths:
      - /api/v1/auth/login
      - /api/v1/auth/register
      - /api/v1/auth/refresh
      - /api/v1/auth/logout
      - /api/v1/health
      - /error
  cors:
    allowed-origin-patterns: http://localhost:5573,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
  collaboration:
    ticket-secret: replace-with-a-random-collaboration-secret
    ticket-ttl: 60s
    websocket-url: ws://127.0.0.1:8180
    service-token: replace-with-a-random-service-token
  bootstrap:
    security-data-enabled: true
    admin:
      enabled: false
      username:
      password:
      nickname:
      email:
      phone:
